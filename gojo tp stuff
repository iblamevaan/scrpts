-- Six Eyes + Fly LocalScript
-- Place inside StarterCharacterScripts

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local sixEyesOn = false
local effects = {}
local espConnections = {}
local espBillboards = {}

local flyOn = false
local flyBodyVelocity = nil
local flyBodyGyro = nil
local flyConn = nil

local tpCooldown = false

------------------------------------------------
-- CLEANUP
------------------------------------------------
local function cleanupEffects()
    for _, v in ipairs(effects) do
        if typeof(v) == "RBXScriptConnection" then
            pcall(function() v:Disconnect() end)
        else
            pcall(function() v:Destroy() end)
        end
    end
    effects = {}
end

local function cleanupESP()
    for _, conn in ipairs(espConnections) do
        pcall(function() conn:Disconnect() end)
    end
    espConnections = {}
    for _, bb in pairs(espBillboards) do
        pcall(function() bb:Destroy() end)
    end
    espBillboards = {}
end

------------------------------------------------
-- SCREEN EFFECTS
------------------------------------------------
local function applyScreenEffects()
    local cc = Instance.new("ColorCorrectionEffect")
    cc.TintColor = Color3.fromRGB(180, 220, 255)
    cc.Brightness = 0.04
    cc.Contrast = 0.1
    cc.Saturation = 0.2
    cc.Parent = Lighting
    table.insert(effects, cc)

    local bloom = Instance.new("BloomEffect")
    bloom.Intensity = 0.8
    bloom.Size = 24
    bloom.Threshold = 0.9
    bloom.Parent = Lighting
    table.insert(effects, bloom)

    local dof = Instance.new("DepthOfFieldEffect")
    dof.FarIntensity = 0.3
    dof.NearIntensity = 0
    dof.FocusDistance = 40
    dof.InFocusRadius = 20
    dof.Parent = Lighting
    table.insert(effects, dof)

    local sunRays = Instance.new("SunRaysEffect")
    sunRays.Intensity = 0.08
    sunRays.Spread = 0.5
    sunRays.Parent = Lighting
    table.insert(effects, sunRays)
end

------------------------------------------------
-- HEAD LIGHT
------------------------------------------------
local function createHeadLight(character)
    local head = character:WaitForChild("Head")
    local light = Instance.new("PointLight")
    light.Color = Color3.fromRGB(100, 180, 255)
    light.Brightness = 3
    light.Range = 18
    light.Parent = head
    table.insert(effects, light)
end

------------------------------------------------
-- ESP
------------------------------------------------
local function createESPForPlayer(target)
    if target == player then return end
    local targetChar = target.Character
    if not targetChar then return end
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 120, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.LightInfluence = 0
    billboard.Parent = targetHRP
    espBillboards[target.UserId] = billboard

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.6, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = target.Name
    nameLabel.TextColor3 = Color3.fromRGB(120, 200, 255)
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextScaled = true
    nameLabel.Parent = billboard

    local distLabel = Instance.new("TextLabel")
    distLabel.Size = UDim2.new(1, 0, 0.4, 0)
    distLabel.Position = UDim2.new(0, 0, 0.6, 0)
    distLabel.BackgroundTransparency = 1
    distLabel.Text = "0 studs"
    distLabel.TextColor3 = Color3.fromRGB(200, 230, 255)
    distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    distLabel.TextStrokeTransparency = 0
    distLabel.Font = Enum.Font.Gotham
    distLabel.TextScaled = true
    distLabel.Parent = billboard

    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(0, 120, 255)
    highlight.OutlineColor = Color3.fromRGB(150, 210, 255)
    highlight.FillTransparency = 0.7
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = targetChar
    table.insert(effects, highlight)

    local conn = RunService.Heartbeat:Connect(function()
        if not targetHRP or not targetHRP.Parent then return end
        local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        local dist = math.floor((targetHRP.Position - myHRP.Position).Magnitude)
        distLabel.Text = dist .. " studs"
        local t = math.clamp(dist / 100, 0, 1)
        nameLabel.TextColor3 = Color3.fromRGB(
            math.floor(255 * (1 - t)),
            math.floor(120 + 80 * t),
            255
        )
    end)
    table.insert(espConnections, conn)
end

local function setupESP()
    for _, target in ipairs(Players:GetPlayers()) do
        createESPForPlayer(target)
    end

    local joinConn = Players.PlayerAdded:Connect(function(target)
        if not sixEyesOn then return end
        target.CharacterAdded:Connect(function()
            task.wait(0.5)
            createESPForPlayer(target)
        end)
        createESPForPlayer(target)
    end)
    table.insert(espConnections, joinConn)

    for _, target in ipairs(Players:GetPlayers()) do
        if target ~= player then
            local respawnConn = target.CharacterAdded:Connect(function()
                if not sixEyesOn then return end
                task.wait(0.5)
                if espBillboards[target.UserId] then
                    pcall(function() espBillboards[target.UserId]:Destroy() end)
                    espBillboards[target.UserId] = nil
                end
                createESPForPlayer(target)
            end)
            table.insert(espConnections, respawnConn)
        end
    end
end

------------------------------------------------
-- BLACK AFTERIMAGE
------------------------------------------------
local function spawnAfterimage(character)
    local afterimage = Instance.new("Model")
    afterimage.Parent = workspace

    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local clone = Instance.new("Part")
            clone.Size = part.Size
            clone.CFrame = part.CFrame
            clone.Anchored = true
            clone.CanCollide = false
            clone.CastShadow = false
            clone.Material = Enum.Material.ForceField
            clone.Color = Color3.fromRGB(0, 0, 0)
            clone.Transparency = 0.1
            clone.Parent = afterimage
        end
    end

    task.spawn(function()
        for i = 1, 12 do
            task.wait(0.03)
            for _, p in ipairs(afterimage:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.Transparency = 0.1 + (i / 12) * 0.9
                end
            end
        end
        afterimage:Destroy()
    end)
end

------------------------------------------------
-- TELEPORT TO MOUSE
------------------------------------------------
local function doTeleport()
    if tpCooldown then return end
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- use mouse.Hit which is the most reliable way to get
    -- exactly where the mouse is pointing in 3D space
    local mouse = player:GetMouse()
    local targetPos = mouse.Hit.Position

    -- add a small upward offset so we land on top of surface
    targetPos = targetPos + Vector3.new(0, 3, 0)

    tpCooldown = true

    -- afterimage at current position before teleporting
    spawnAfterimage(character)

    -- sound at old position
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://133355435926719"
    sound.Volume = 2
    sound.Parent = hrp
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 4)

    -- teleport keeping rotation
    hrp.CFrame = CFrame.new(targetPos) * (hrp.CFrame - hrp.CFrame.Position)

    task.wait(0.5)
    tpCooldown = false
end

------------------------------------------------
-- FLY
------------------------------------------------
local FLY_SPEED = 80
local FLY_ACCEL = 8

local function isShiftLocked()
    return UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter
end

local function enableFly()
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end

    humanoid.PlatformStand = true

    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.Velocity = Vector3.zero
    flyBodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    flyBodyVelocity.P = 1e4
    flyBodyVelocity.Parent = hrp

    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    flyBodyGyro.P = 1e4
    flyBodyGyro.D = 400
    flyBodyGyro.CFrame = hrp.CFrame
    flyBodyGyro.Parent = hrp

    local currentVelocity = Vector3.zero

    flyConn = RunService.Heartbeat:Connect(function(dt)
        if not hrp or not hrp.Parent then return end

        local camCF = camera.CFrame
        local forward = camCF.LookVector
        local right = camCF.RightVector
        local up = Vector3.new(0, 1, 0)
        local moveDir = Vector3.zero
        local speed = FLY_SPEED
        local shiftLocked = isShiftLocked()

        if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Up) then
            if shiftLocked then
                moveDir = moveDir + forward
            else
                local flat = Vector3.new(forward.X, 0, forward.Z)
                if flat.Magnitude > 0 then moveDir = moveDir + flat.Unit end
            end
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Down) then
            if shiftLocked then
                moveDir = moveDir - forward
            else
                local flat = Vector3.new(forward.X, 0, forward.Z)
                if flat.Magnitude > 0 then moveDir = moveDir - flat.Unit end
            end
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left) then
            moveDir = moveDir - right
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then
            moveDir = moveDir + right
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveDir = moveDir + up
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
            moveDir = moveDir - up
        end

        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit * speed
        end

        currentVelocity = currentVelocity:Lerp(moveDir, math.min(dt * FLY_ACCEL, 1))
        flyBodyVelocity.Velocity = currentVelocity

        if shiftLocked then
            flyBodyGyro.CFrame = camCF
        else
            local flatLook = Vector3.new(forward.X, 0, forward.Z)
            if flatLook.Magnitude > 0 then
                flyBodyGyro.CFrame = CFrame.new(Vector3.zero, flatLook.Unit)
            end
        end

        if moveDir.Magnitude < 1 then
            local bob = math.sin(tick() * 1.5) * 0.08
            flyBodyVelocity.Velocity = Vector3.new(currentVelocity.X, bob, currentVelocity.Z)
        end
    end)
end

local function disableFly()
    local character = player.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.PlatformStand = false end
    end
    if flyConn then flyConn:Disconnect() flyConn = nil end
    if flyBodyVelocity then flyBodyVelocity:Destroy() flyBodyVelocity = nil end
    if flyBodyGyro then flyBodyGyro:Destroy() flyBodyGyro = nil end
end

------------------------------------------------
-- SIX EYES TOGGLE
------------------------------------------------
local function enableSixEyes()
    local character = player.Character
    if not character then return end
    applyScreenEffects()
    createHeadLight(character)
    setupESP()
end

local function disableSixEyes()
    cleanupEffects()
    cleanupESP()
end

------------------------------------------------
-- INPUT
------------------------------------------------
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Enum.KeyCode.T then
        sixEyesOn = not sixEyesOn
        if sixEyesOn then enableSixEyes() else disableSixEyes() end
    end

    if input.KeyCode == Enum.KeyCode.F then
        flyOn = not flyOn
        if flyOn then enableFly() else disableFly() end
    end

    if input.KeyCode == Enum.KeyCode.E then
        doTeleport()
    end
end)

player.CharacterAdded:Connect(function()
    flyOn = false
    disableFly()
    if sixEyesOn then
        disableSixEyes()
        task.wait(1)
        enableSixEyes()
    end
end)
